{
  "name": "hour-calculator",
  "version": "1.0.0",
  "private": true,
  "description": "A simple MERN weekly hour and pay calculator.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "mongo": "powershell -ExecutionPolicy Bypass -File ./scripts/start-mongo.ps1",
    "dev": "powershell -ExecutionPolicy Bypass -File ./scripts/start-dev.ps1",
    "server": "node server/index.js",
    "client": "npm run build --prefix client",
    "start": "node server/index.js",
    "build": "npm install --prefix client --ignore-scripts && npm run build --prefix client",
    "deploy:build": "npm run build",
    "install:all": "npm install && npm install --prefix client"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5"
  },
  "devDependencies": {}
}
